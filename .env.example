# The CRM uses TWO Supabase projects — internal staff auth is kept separate
# from customer data on purpose (internal employees are not customers).
# Copy to .env.local and fill in. Never commit .env.local.

# --- Staff auth: RusalkaOps internal project (internal employees only) ---
# Dev = test branch (ijzxk…); prod = main (xjacs…), set in the deploy env.
NEXT_PUBLIC_SUPABASE_URL=https://ijzxksujnhrrolcpvrsy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Customer data: ecommerce project (customers, orders, quiz, catalog) ---
# Read server-side via the service role. Dev = test branch (uieuy…);
# prod = main (kdjcb…), set in the deploy env. Server-only — never NEXT_PUBLIC.
DATA_SUPABASE_URL=https://uieuyprfexopmxgivssl.supabase.co
DATA_SUPABASE_SERVICE_ROLE_KEY=

